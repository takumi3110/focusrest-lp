    [data-reveal] { animation: none; opacity: 1; transform: none; }
  }
</style>

<script>
  type Phase = { key: 'fight' | 'rest'; label: string; sub: string; total: number; next: string }

  const phases: Phase[] = [
    { key: 'fight', label: 'FIGHT', sub: '集中', total: 25 * 60, next: '休憩 5:00' },
    { key: 'rest', label: 'REST', sub: '整える', total: 5 * 60, next: '集中 25:00' },
  ]

  const DEMO_MS = 9000 // wall-clock time to play one phase in the hero demo

  const hero = document.querySelector<HTMLElement>('.hero')
  const ring = document.querySelector<HTMLElement>('[data-tmr="ring"]')
  const els = {
    label: document.querySelector<HTMLElement>('[data-tmr="label"]'),
    sub: document.querySelector<HTMLElement>('[data-tmr="sub"]'),
    time: document.querySelector<HTMLElement>('[data-tmr="time"]'),
    total: document.querySelector<HTMLElement>('[data-tmr="total"]'),
    set: document.querySelector<HTMLElement>('[data-tmr="set"]'),
    next: document.querySelector<HTMLElement>('[data-tmr="next"]'),
  }

  const fmt = (s: number) => {
    const m = Math.floor(s / 60)
    const sec = Math.floor(s % 60)
    return `${m}:${sec.toString().padStart(2, '0')}`
  }

  const render = (phase: Phase, remain: number, progress: number, set: number) => {
    if (els.label) els.label.textContent = phase.label
    if (els.sub) els.sub.textContent = phase.sub
    if (els.time) els.time.textContent = fmt(remain)
    if (els.total) els.total.textContent = fmt(phase.total)
    if (els.next) els.next.textContent = phase.next
    if (els.set) els.set.textContent = String(set)
    if (ring) ring.style.setProperty('--p', progress.toFixed(4))
    if (hero) hero.dataset.phase = phase.key
  }

  if (hero && ring) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduce) {
      // static, representative state
      render(phases[0], 16 * 60, 0.64, 1)
    } else {
      let idx = 0
      let set = 1
      let start = performance.now()

      const tick = (now: number) => {
        const phase = phases[idx]
        const f = Math.min((now - start) / DEMO_MS, 1)
        const remain = Math.ceil(phase.total * (1 - f))
        render(phase, remain, 1 - f, set)

        if (f >= 1) {
          // advance; one completed REST closes a set (cap the display at 4)
          if (phase.key === 'rest') set = (set % 4) + 1
          idx = (idx + 1) % phases.length
          start = now
        }
        requestAnimationFrame(tick)
      }
      requestAnimationFrame(tick)
    }
  }
</script>
