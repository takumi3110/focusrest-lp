---
import Layout from '../layouts/Layout.astro'
import timerImg from '../assets/timer.png'
import settingsImg from '../assets/settings.png'
import timerListImg from '../assets/list.png'
import appStoreBadge from '../assets/app_store_badge_jp_white.svg'

const features = [
  {
    no: '01',
    icon: '⏱',
    title: 'カスタムタイマー',
    description: '作業・休憩・セット数を自由に設定。ポモドーロでも筋トレのインターバルでも、自分の型に合わせられる。',
  },
  {
    no: '02',
    icon: '🔔',
    title: '残り時間お知らせ',
    description: 'フェーズ終了前に音でカウントダウン。画面を見なくても、次のアクションへ自然に切り替わる。',
  },
  {
    no: '03',
    icon: '🎵',
    title: 'アラーム音カスタマイズ',
    description: 'FIGHTとRESTのアラーム音を別々に設定。音だけで「今どっちの時間か」が体に染み込む。',
  },
  {
    no: '04',
    icon: '🎨',
    title: 'テーマカスタマイズ',
    description: 'アクセントカラーとライト/ダークを自由に変更。毎日見る画面を、自分の気分に合わせて。',
  },
]

const screens = [
  { src: timerImg, label: 'タイマー', note: '今のフェーズと残り時間が、ひと目で。' },
  { src: settingsImg, label: '設定', note: '時間・音・セット数を細かく調整。' },
  { src: timerListImg, label: 'タイマーリスト', note: 'よく使う型を保存して、即スタート。' },
]
---

<Layout>
  <!-- ========== HEADER ========== -->
  <header class="header">
    <div class="container header-inner">
      <a href="#top" class="logo">
        <span class="logo-fight">Fight</span><span class="logo-and">and</span><span class="logo-rest">Rest</span>
      </a>
      <a href="#download" class="header-cta">無料で始める</a>
    </div>
  </header>

  <!-- ========== HERO ========== -->
  <section class="hero" id="top" data-phase="fight">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">iOS · INTERVAL TIMER</span>
        <h1 class="hero-title">集中と休憩を、<br />あなたのリズムに。</h1>
        <p class="hero-sub">仕事も筋トレも、インターバルでメリハリを。</p>
        <p class="hero-desc">
          <b class="hl hl-fight">FIGHT</b> と <b class="hl hl-rest">REST</b> を行き来するだけ。
          カスタムの時間・音・テーマで、自分だけのリズムを刻める。
        </p>

        <div class="hero-actions" id="download">
          <a href="#" class="appstore-btn" aria-label="App Store でダウンロード">
            <img src={appStoreBadge.src} alt="App Store でダウンロード" width="160" height="48" />
          </a>
        </div>

        <ul class="legend" aria-hidden="true">
          <li class="leg leg-fight"><span class="leg-dot"></span>FIGHT<small>集中する時間</small></li>
          <li class="leg leg-rest"><span class="leg-dot"></span>REST<small>整える時間</small></li>
        </ul>
      </div>

      <!-- Signature: a live interval timer running inside the phone -->
      <div class="hero-device">
        <div class="device" data-reveal>
          <div class="device-notch" aria-hidden="true"></div>
          <div class="device-screen">
            <div class="app-statusbar" aria-hidden="true">
              <span>9:41</span>
              <span class="app-name">FightandRest</span>
              <span>􀙇</span>
            </div>

            <div class="tmr" role="img" aria-label="インターバルタイマーのデモ。FIGHTとRESTを切り替えながらカウントダウンします。">
              <div class="tmr-phase">
                <span class="tmr-phase-label" data-tmr="label">FIGHT</span>
                <span class="tmr-phase-sub" data-tmr="sub">集中</span>
              </div>

              <div class="tmr-ring" data-tmr="ring">
                <div class="tmr-core">
                  <div class="tmr-time" data-tmr="time">25:00</div>
                  <div class="tmr-total">/ <span data-tmr="total">25:00</span></div>
                </div>
              </div>

              <div class="tmr-meta">
                <div class="tmr-set">SET <b data-tmr="set">1</b> / 4</div>
                <div class="tmr-next">NEXT · <span data-tmr="next">休憩 5:00</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURES ========== -->
  <section class="block features pole-fight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">TOOLKIT / 機能</span>
        <h2 class="section-title">リズムを作る、4つの調整つまみ</h2>
      </div>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <span class="feature-no">{f.no}</span>
            <div class="feature-icon">{f.icon}</div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== SCREENSHOTS ========== -->
  <section class="block screenshots pole-rest">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">SCREENS / 画面</span>
        <h2 class="section-title">迷わず使える、整った画面</h2>
      </div>
      <div class="screenshots-grid">
        {screens.map((item) => (
          <figure class="screenshot-card">
            <div class="screenshot-frame">
              <img src={item.src.src} alt={`${item.label}の画面`} loading="lazy" />
            </div>
            <figcaption class="screenshot-cap">
              <span class="screenshot-label">{item.label}</span>
              <span class="screenshot-note">{item.note}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== USE CASES ========== -->
  <section class="block use-cases pole-fight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">SCENES / 使いどころ</span>
        <h2 class="section-title">FIGHT も REST も、選ばない</h2>
      </div>
      <div class="use-cases-grid">
        <div class="use-case-card">
          <div class="use-case-emoji">📚</div>
          <h3>勉強・仕事に</h3>
          <p>25分集中＋5分休憩のポモドーロで、長いタスクも息切れせずに走り切る。</p>
        </div>
        <div class="use-case-card">
          <div class="use-case-emoji">💪</div>
          <h3>筋トレ・運動に</h3>
          <p>運動と休憩の時間、セット数を決めて開始。数えるのはアプリに任せて、体に集中。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="block pricing pole-rest">
    <div class="container">
      <div class="section-head section-head--center">
        <span class="eyebrow">ACCESS / 料金</span>
        <h2 class="section-title">まず無料で、リズムを試す</h2>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-label">無料</div>
          <div class="pricing-price">¥0</div>
          <ul class="pricing-features">
            <li>すべてのタイマー機能</li>
            <li>カスタムサウンド</li>
            <li>テーマカスタマイズ</li>
            <li class="muted">広告あり</li>
          </ul>
        </div>
        <div class="pricing-card pricing-card--premium">
          <div class="pricing-badge">おすすめ</div>
          <div class="pricing-label">プレミアム</div>
          <div class="pricing-price">買い切り</div>
          <ul class="pricing-features">
            <li>無料のすべての機能</li>
            <li><strong>広告なし</strong></li>
            <li class="muted">一度の購入でずっと</li>
          </ul>
        </div>
      </div>
      <div class="pricing-cta">
        <a href="#" class="appstore-btn" aria-label="App Store でダウンロード">
          <img src={appStoreBadge.src} alt="App Store でダウンロード" width="160" height="48" />
        </a>
      </div>
    </div>
  </section>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <span class="logo-fight">Fight</span><span class="logo-and">and</span><span class="logo-rest">Rest</span>
      </div>
      <nav class="footer-nav" aria-label="フッター">
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/terms">利用規約</a>
      </nav>
      <p class="footer-copy">© 2026 garitto All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  /* ───────────── Header ───────────── */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(14, 14, 19, 0.72);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
    padding: 14px 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text);
  }

  .logo-fight { color: var(--fight); }
  .logo-and   { color: var(--text-mute); margin: 0 1px; font-weight: 600; }
  .logo-rest  { color: var(--rest); }

  .header-cta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text);
    border: 1px solid var(--line-strong);
    padding: 9px 18px;
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .header-cta:hover {
    border-color: var(--fight);
    color: var(--fight-soft);
    background: var(--fight-glow);
  }

  /* ───────────── Hero ───────────── */
  .hero {
    position: relative;
    padding: 96px 0 88px;
    overflow: hidden;
    /* the active pole follows the live timer phase via [data-phase] */
    --accent: var(--fight);
    --accent-soft: var(--fight-soft);
    --accent-glow: var(--fight-glow);
    transition: --accent 0.6s;
  }

  .hero[data-phase='rest'] {
    --accent: var(--rest);
    --accent-soft: var(--rest-soft);
    --accent-glow: var(--rest-glow);
  }

  /* two opposing glows — the one matching the current phase intensifies */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(620px 480px at 88% -8%, var(--fight-glow), transparent 60%),
      radial-gradient(560px 460px at 6% 112%, var(--rest-glow), transparent 60%);
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(680px 540px at 70% 18%, var(--accent-glow), transparent 62%);
    opacity: 0.9;
    transition: background 0.6s ease;
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }

  .hero-title {
    font-family: var(--font-body);
    font-size: clamp(2.1rem, 5.4vw, 3.4rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: 0.01em;
    margin: 18px 0 18px;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.2vw, 1.4rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 14px;
  }

  .hero-desc {
    color: var(--text-mute);
    font-size: 0.98rem;
    max-width: 440px;
    margin-bottom: 34px;
  }

  .hl {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.92em;
    letter-spacing: 0.04em;
  }
  .hl-fight { color: var(--fight-soft); }
  .hl-rest  { color: var(--rest-soft); }

  .hero-actions { margin-bottom: 32px; }

  .appstore-btn {
    display: inline-block;
    transition: opacity 0.15s, transform 0.15s;
  }
  .appstore-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .appstore-btn img { height: 48px; width: auto; }

  /* fight/rest legend */
  .legend {
    list-style: none;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .leg {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 7px 14px;
    transition: color 0.4s, border-color 0.4s, background 0.4s;
  }
  .leg small {
    font-family: var(--font-body);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--text-mute);
  }
  .leg-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: currentColor;
  }
  .leg-fight { color: var(--fight); }
  .leg-rest  { color: var(--rest); }

  /* active phase chip lights up */
  .hero[data-phase='fight'] .leg-fight,
  .hero[data-phase='rest'] .leg-rest {
    border-color: var(--accent);
    background: var(--accent-glow);
    color: var(--accent-soft);
  }
  .hero[data-phase='fight'] .leg-fight .leg-dot { box-shadow: 0 0 12px var(--fight); }
  .hero[data-phase='rest'] .leg-rest .leg-dot { box-shadow: 0 0 12px var(--rest); }

  /* ───────── Phone + live timer ───────── */
  .hero-device {
    display: flex;
    justify-content: center;
  }

  .device {
    position: relative;
    width: 290px;
    padding: 12px;
    border-radius: 46px;
    background: linear-gradient(160deg, #23232e, #101016);
    border: 1px solid var(--line-strong);
    box-shadow:
      0 40px 80px -30px rgba(0, 0, 0, 0.9),
      0 0 70px -10px var(--accent-glow);
    transition: box-shadow 0.6s ease;
  }

  .device-notch {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 92px;
    height: 22px;
    background: #0a0a0e;
    border-radius: 0 0 14px 14px;
    z-index: 2;
  }

  .device-screen {
    position: relative;
    border-radius: 36px;
    aspect-ratio: 9 / 19.3;
    background:
      radial-gradient(120% 70% at 50% 0%, var(--accent-glow), transparent 60%),
      #0a0a0e;
    overflow: hidden;
    padding: 16px 18px 22px;
    display: flex;
    flex-direction: column;
    transition: background 0.6s ease;
  }

  .app-statusbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-mute);
    padding: 6px 4px 0;
  }
  .app-statusbar .app-name {
    color: var(--accent-soft);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .tmr {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 22px;
  }

  .tmr-phase { text-align: center; }
  .tmr-phase-label {
    display: block;
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: var(--accent);
    transition: color 0.5s ease;
  }
  .tmr-phase-sub {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--text-mute);
    letter-spacing: 0.2em;
  }

  .tmr-ring {
    --p: 1;
    position: relative;
    width: 188px;
    height: 188px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: conic-gradient(
      var(--accent) calc(var(--p) * 360deg),
      rgba(255, 255, 255, 0.07) 0
    );
  }
  .tmr-ring::before {
    content: '';
    position: absolute;
    inset: 13px;
    border-radius: 50%;
    background: #0a0a0e;
    box-shadow: inset 0 0 24px rgba(0, 0, 0, 0.6);
  }

  .tmr-core { position: relative; text-align: center; }
  .tmr-time {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .tmr-total {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-mute);
    margin-top: 2px;
  }

  .tmr-meta {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--text-mute);
  }
  .tmr-set b { color: var(--text); }
  .tmr-next { color: var(--accent-soft); transition: color 0.5s ease; }

  /* ───────────── Shared blocks ───────────── */
  .block { padding: 96px 0; }

  .block + .block { border-top: 1px solid var(--line); }

  .section-head--center { text-align: center; }

  /* ───────────── Features ───────────── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(228px, 1fr));
    gap: 20px;
  }

  .feature-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 30px 24px 26px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .feature-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0;
    width: 100%; height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }
  .feature-card:hover::before { transform: scaleX(1); }

  .feature-no {
    position: absolute;
    top: 18px;
    right: 20px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-mute);
    letter-spacing: 0.08em;
  }
  .feature-icon { font-size: 1.7rem; margin-bottom: 16px; }
  .feature-title {
    font-size: 1.02rem;
    font-weight: 700;
    margin-bottom: 9px;
    color: var(--text);
  }
  .feature-desc {
    font-size: 0.86rem;
    color: var(--text-mute);
    line-height: 1.8;
  }

  /* ───────────── Screenshots ───────────── */
  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .screenshot-card { margin: 0; }

  .screenshot-frame {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 22px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .screenshot-card:hover .screenshot-frame {
    border-color: var(--accent);
    transform: translateY(-4px);
  }
  .screenshot-frame img { width: 100%; height: auto; }

  .screenshot-cap {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 16px 4px 0;
  }
  .screenshot-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--accent-soft);
  }
  .screenshot-note {
    font-size: 0.82rem;
    color: var(--text-mute);
  }

  /* ───────────── Use cases ───────────── */
  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .use-case-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 18px;
    padding: 34px 30px;
  }
  .use-case-emoji { font-size: 2.4rem; margin-bottom: 14px; }
  .use-case-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
  }
  .use-case-card p {
    font-size: 0.9rem;
    color: var(--text-mute);
  }

  /* ───────────── Pricing ───────────── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 20px;
    max-width: 620px;
    margin: 0 auto;
  }
  .pricing-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 34px 30px;
  }
  .pricing-card--premium {
    border-color: var(--accent);
    box-shadow: 0 0 40px -12px var(--accent-glow);
  }
  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    background: var(--accent);
    color: #0a0a0d;
    padding: 4px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }
  .pricing-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-mute);
    margin-bottom: 6px;
  }
  .pricing-price {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--accent-soft);
    margin-bottom: 22px;
