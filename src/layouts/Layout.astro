---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'FocusRest — 集中と休憩を、あなたのリズムに。',
  description = '仕事も筋トレも、インターバルでメリハリを。カスタムタイマーとアラーム音で集中（FOCUS）と休憩（REST）を最適化するiOSアプリ。',
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@500;600;700;800&family=Space+Mono:wght@400;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* base — neutral ink so both poles read cleanly */
    --ink: #0e0e13;
    --surface: #16161e;
    --surface-2: #1d1d28;
    --text: #ecebf4;
    --text-mute: #928fa0;
    --line: rgba(255, 255, 255, 0.09);
    --line-strong: rgba(255, 255, 255, 0.16);

    /* focus pole — ember / burn / effort */
    --focus: #ff5a36;
    --focus-soft: #ff8a5e;
    --focus-glow: rgba(255, 90, 54, 0.26);

    /* REST pole — recovery mint / breath / calm */
    --rest: #2fe0b6;
    --rest-soft: #79eed4;
    --rest-glow: rgba(47, 224, 182, 0.22);

    /* per-section accent; overridden by .pole-focus / .pole-rest */
    --accent: var(--focus);
    --accent-soft: var(--focus-soft);
    --accent-glow: var(--focus-glow);

    --font-display: 'Saira Condensed', 'Noto Sans JP', sans-serif;
    --font-mono: 'Space Mono', monospace;
    --font-body: 'Noto Sans JP', sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--ink);
    color: var(--text);
    font-family: var(--font-body);
    line-height: 1.75;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3 {
    line-height: 1.2;
  }

  a {
    color: var(--accent-soft);
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  ::selection {
    background: var(--accent);
    color: #0a0a0d;
  }

  :focus-visible {
    outline: 2px solid var(--accent-soft);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* mono eyebrow — the page's structural voice (timer-panel language) */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .eyebrow::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
  }

  .section-head {
    margin-bottom: 48px;
  }

  .section-title {
    font-family: var(--font-body);
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    font-weight: 700;
    margin-top: 12px;
    letter-spacing: 0.01em;
  }

  /* pole accent overrides — drive the focus⇄REST rhythm across sections */
  .pole-focus {
    --accent: var(--focus);
    --accent-soft: var(--focus-soft);
    --accent-glow: var(--focus-glow);
  }

  .pole-rest {
    --accent: var(--rest);
    --accent-soft: var(--rest-soft);
    --accent-glow: var(--rest-glow);
  }
</style>
